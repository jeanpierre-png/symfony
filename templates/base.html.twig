<!DOCTYPE html>

<html>

    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Stubborn{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/home.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/shop.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/product.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/cart.css') }}">
        <link rel="stylesheet" href="{{ asset('styles/admin.css') }}">
    </head>

    <body>

        <header class="header">

            <div class="logo">
                <img src="{{ asset('images/Logo.png') }}" alt="Logo Stubborn">
                <p>Slogan</p>
            </div>


            {% if app.request.attributes.get('_route') starts with 'app_admin' %}

                <div class="title-admin">
                    <h1>Back-Office</h1>
                </div>

                <nav>

                    <a href="{{ path('app_shop') }}">Boutique</a>

                    {% if app.user %}
                        <a href="{{ path('app_logout') }}">Se déconnecter</a>
                    {% endif %}
                </nav>

            {% else %}

                <nav>

                    <a  class="{% if app.request.attributes.get('_route') == 'app_home' %}active-link{% endif %}" 
                        href="{{ path('app_home') }}">Accueil
                    </a>

                    {% if app.user %}
                                    
                        <a  class="{% if app.request.attributes.get('_route') == 'app_shop' %}active-link{% endif %}" 
                            href="{{ path('app_shop') }}"
                        >
                            Boutique
                        </a>
                        <a  class="{% if app.request.attributes.get('_route') == 'app_cart' %}active-link{% endif %}"  
                            href="{{ path('app_cart') }}"
                        >
                            Panier
                        </a>
                        <a  class="{% if app.request.attributes.get('_route') == 'app_logout' %}active-link{% endif %}" 
                            href="{{ path('app_logout') }}"
                        >
                            Se déconnecter
                        </a>

                    {% else %}   

                        <a  class="{% if app.request.attributes.get('_route') == 'app_register' %}active-link{% endif %}"  
                            href="{{ path('app_register') }}"
                        >
                            S'inscrire
                        </a>
                        <a  class="{% if app.request.attributes.get('_route') == 'app_login' %}active-link{% endif %}"  
                            href="{{ path('app_login') }}"
                        >
                            Se connecter
                        </a>

                    {% endif %}
                </nav> 

            {% endif %} 

        </header>

        <main>
            {% block body %}{% endblock %}
        </main>

        <footer class="footer">

            <div class="footer-content">

                <div class="footer-section">
                    <h3>Nom de la société</h3>
                    <p>Stubborn</p>
                </div>

                <div class="footer-section">
                    <h3>Adresse</h3>
                    <p>Piccadilly Circus,</p>
                    <p>London W1J 0DA,</p>
                    <p>Royaume-Uni</p>
                </div>

                <div class="footer-section">
                    <h3>Adresse de contact</h3>
                    <p>stubborn@blabla.com</p>
                </div>

                <div class="footer-section">
                    <h3>Slogan</h3>
                    <p>Don't compromise on your look</p>
                </div>
            </div>
        </footer>
    </body>
</html>
